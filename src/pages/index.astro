---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import Header from '../components/Header.astro';
import DocumentView from '../components/DocumentView.astro';
import AlertPanel from '../components/AlertPanel.astro';
import Footer from '../components/Footer.astro';
import DashboardView from '../components/views/DashboardView.astro';
import PoliticasView from '../components/views/PoliticasView.astro';
import FlujosView from '../components/views/FlujosView.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>TransparencIA - Dashboard</title>
  </head>
  <body class="font-sans antialiased text-slate-800">
    <div class="flex h-screen overflow-hidden bg-slate-50">
      
      <Sidebar />

      <!-- Main Content (Derecha) -->
      <main class="flex-1 flex flex-col relative overflow-hidden bg-slate-50/50">
        
        <Header />

        <div class="flex-1 overflow-auto p-8 relative w-full h-full">
          <!-- View: analysis -->
          <div data-view-container="analysis" class="w-full h-full">
            <div class="grid grid-cols-2 gap-8 max-w-7xl mx-auto h-full">
              <DocumentView />
              <AlertPanel />
            </div>
          </div>

          <!-- View: dashboard -->
          <div data-view-container="dashboard" class="w-full h-full hidden">
            <DashboardView />
          </div>

          <!-- View: politicas -->
          <div data-view-container="politicas" class="w-full h-full hidden">
            <PoliticasView />
          </div>

          <!-- View: flujos -->
          <div data-view-container="flujos" class="w-full h-full hidden">
            <FlujosView />
          </div>
        </div>

        <div data-view-footer="analysis">
          <Footer />
        </div>

      </main>
    </div>

    <script>
      import { $currentView } from '../store/routerStore';

      $currentView.subscribe(view => {
        // Toggle view containers
        document.querySelectorAll('[data-view-container]').forEach(el => {
          if (el.getAttribute('data-view-container') === view) {
            el.classList.remove('hidden');
          } else {
            el.classList.add('hidden');
          }
        });

        // Toggle footer (only show in analysis view)
        const footer = document.querySelector('[data-view-footer="analysis"]');
        if (footer) {
          if (view === 'analysis') {
            footer.classList.remove('hidden');
          } else {
            footer.classList.add('hidden');
          }
        }
      });
    </script>
  </body>
</html>
