---
import { CheckCircle2, Clock, XCircle, ArrowRight } from 'lucide-react';

const flows = [
  { id: 'REQ-2025-001', doc: 'Contrato TECH SOLUTIONS', res: 'Adrián Felipe Ochoa H', initials: 'AFO', state: 'Aprobado', date: '01 May 2025' },
  { id: 'REQ-2025-002', doc: 'Adquisición Equipos TI', res: 'Carlos Ramírez', initials: 'CR', state: 'Pendiente', date: '04 May 2025' },
  { id: 'REQ-2025-003', doc: 'Servicios de Aseo', res: 'Ana Martínez', initials: 'AM', state: 'Pendiente', date: '05 May 2025' },
  { id: 'REQ-2025-004', doc: 'Consultoría Externa', res: 'Luis Torres', initials: 'LT', state: 'Rechazado', date: '06 May 2025' },
];
---

<div class="max-w-6xl mx-auto space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-500">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h2 class="text-2xl font-bold text-slate-800">Flujos de Aprobación</h2>
      <p class="text-slate-500 mt-1">Gestión y estado de las revisiones de contratos.</p>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 text-sm">
          <th class="py-4 px-6 font-semibold w-32">ID</th>
          <th class="py-4 px-6 font-semibold">Documento</th>
          <th class="py-4 px-6 font-semibold">Responsable</th>
          <th class="py-4 px-6 font-semibold">Fecha</th>
          <th class="py-4 px-6 font-semibold">Estado</th>
          <th class="py-4 px-6 font-semibold text-right">Acción</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {flows.map(flow => (
          <tr class="hover:bg-slate-50/50 transition-colors group">
            <td class="py-4 px-6 text-sm font-medium text-slate-400">{flow.id}</td>
            <td class="py-4 px-6 font-semibold text-slate-800">{flow.doc}</td>
            <td class="py-4 px-6 text-slate-600 flex items-center gap-2">
              <div class="w-6 h-6 rounded-full bg-slate-200 flex items-center justify-center text-[10px] font-bold text-slate-500">
                {flow.initials}
              </div>
              {flow.res}
            </td>
            <td class="py-4 px-6 text-sm text-slate-500">{flow.date}</td>
            <td class="py-4 px-6">
              {flow.state === 'Aprobado' && (
                <span class="inline-flex items-center gap-1.5 bg-emerald-50 text-emerald-700 px-2.5 py-1 rounded-full text-xs font-bold border border-emerald-200 shadow-sm">
                  <CheckCircle2 size={12} strokeWidth={3} /> Aprobado
                </span>
              )}
              {flow.state === 'Pendiente' && (
                <span class="inline-flex items-center gap-1.5 bg-orange-50 text-orange-700 px-2.5 py-1 rounded-full text-xs font-bold border border-orange-200 shadow-sm">
                  <Clock size={12} strokeWidth={3} /> Pendiente
                </span>
              )}
              {flow.state === 'Rechazado' && (
                <span class="inline-flex items-center gap-1.5 bg-red-50 text-red-700 px-2.5 py-1 rounded-full text-xs font-bold border border-red-200 shadow-sm">
                  <XCircle size={12} strokeWidth={3} /> Rechazado
                </span>
              )}
            </td>
            <td class="py-4 px-6 text-right">
              <button class="text-slate-400 hover:text-emerald-600 transition-colors p-1.5 rounded-md hover:bg-emerald-50 inline-flex items-center justify-center">
                <ArrowRight size={18} />
              </button>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
