---
import { $activeContract } from '../store/analysisStore';
const contract = $activeContract.get();
---

<div class="bg-white shadow-[0_8px_30px_rgb(0,0,0,0.04)] rounded-xl p-12 overflow-auto relative min-h-[800px] border border-slate-200 ring-1 ring-slate-900/5" id="document-view-root">
  <!-- Decoración tipo hoja -->
  <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-transparent via-slate-100 to-transparent"></div>
  
  <h2 id="doc-title" class="text-2xl font-bold mb-8 text-slate-900 border-b border-slate-100 pb-4">
    {contract.title}
  </h2>
  
  <div id="doc-clauses" class="space-y-6 text-slate-700 leading-relaxed text-justify">
    {contract.clauses.map(clause => {
      const highlightClass =
        clause.highlight === 'red'    ? 'bg-red-100 border-b-2 border-red-400 text-slate-900 px-1 py-0.5 rounded-sm' :
        clause.highlight === 'orange' ? 'bg-orange-100 border-b-2 border-orange-400 text-slate-900 px-1 py-0.5 rounded-sm' :
        clause.highlight === 'green'  ? 'bg-emerald-100/60 border-b-2 border-emerald-400 text-slate-900 px-1 py-0.5 rounded-sm' :
        '';
      return (
        <p>
          {clause.highlight
            ? <span id={`clause-${clause.id}`} class={`${highlightClass} transition-all duration-500`}>{clause.text}</span>
            : <span id={`clause-${clause.id}`}>{clause.text}</span>
          }
        </p>
      );
    })}
  </div>
</div>

<script>
  import { $findings, $activeContract } from '../store/analysisStore';

  // Re-render document when contract changes
  $activeContract.subscribe(contract => {
    const title = document.getElementById('doc-title');
    const clausesContainer = document.getElementById('doc-clauses');
    if (!title || !clausesContainer) return;

    title.textContent = contract.title;
    clausesContainer.innerHTML = '';

    contract.clauses.forEach(clause => {
      const p = document.createElement('p');

      const highlightClass =
        clause.highlight === 'red'    ? 'bg-red-100 border-b-2 border-red-400 text-slate-900 px-1 py-0.5 rounded-sm transition-all duration-500' :
        clause.highlight === 'orange' ? 'bg-orange-100 border-b-2 border-orange-400 text-slate-900 px-1 py-0.5 rounded-sm transition-all duration-500' :
        clause.highlight === 'green'  ? 'bg-emerald-100/60 border-b-2 border-emerald-400 text-slate-900 px-1 py-0.5 rounded-sm transition-all duration-500' :
        'transition-all duration-500';

      const span = document.createElement('span');
      span.id = `clause-${clause.id}`;
      span.className = highlightClass;
      span.textContent = clause.text;

      p.appendChild(span);
      clausesContainer.appendChild(p);
    });
  });

  // Apply resolved text when a finding is resolved
  $findings.subscribe(findings => {
    findings.forEach(finding => {
      if (finding.isResolved) {
        const el = document.getElementById(`clause-${finding.id}`);
        if (el && el.textContent !== finding.suggestedText) {
          el.className = 'text-slate-700 px-1 py-0.5 rounded-sm transition-all duration-500';
          el.style.opacity = '0';
          setTimeout(() => {
            el.textContent = finding.suggestedText;
            el.style.opacity = '1';
            el.classList.add('bg-emerald-50', 'text-emerald-900', 'font-medium');
          }, 300);
        }
      }
    });
  });
</script>
