---
import { Search, Bell, User, AlertCircle } from 'lucide-react';
import { $findings } from '../store/analysisStore';

const findings = $findings.get();
const unresolvedInitialCount = findings.filter(f => !f.isResolved).length;
---

<header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 shrink-0 z-10 shadow-sm">
  <div class="flex items-center gap-4">
    <h1 class="text-xl font-bold text-slate-800">Detalle de Análisis</h1>
    <span class="bg-red-50 text-red-600 px-3 py-1 rounded-full text-xs font-bold tracking-wide flex items-center gap-1.5 border border-red-200 shadow-sm transition-colors duration-300" id="header-findings-badge">
      <AlertCircle size={14} strokeWidth={2.5} />
      <span id="header-findings-count">{unresolvedInitialCount} Hallazgos</span>
    </span>
  </div>
  
  <div class="flex items-center gap-6 text-slate-500">
    <div class="relative group">
      <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-emerald-500 transition-colors" size={18} />
      <input type="text" placeholder="Buscar..." class="pl-10 pr-4 py-2 bg-slate-100/80 border-transparent rounded-lg focus:bg-white focus:border-emerald-300 focus:ring-4 focus:ring-emerald-500/10 outline-none transition-all text-sm w-64 shadow-inner" />
    </div>
    <div class="relative">
      <button id="notification-btn" class="hover:text-slate-800 transition-colors relative flex items-center justify-center p-1 rounded-full hover:bg-slate-100">
        <Bell size={20} />
        <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full border border-white"></span>
      </button>

      <!-- Dropdown -->
      <div id="notification-dropdown" class="absolute right-0 mt-2 w-72 bg-white rounded-xl shadow-lg border border-slate-200 overflow-hidden hidden origin-top-right transition-all transform opacity-0 scale-95 z-50">
        <div class="px-4 py-3 border-b border-slate-100 bg-slate-50 flex justify-between items-center">
          <h4 class="font-bold text-slate-800 text-sm">Notificaciones</h4>
          <span class="text-[10px] uppercase font-bold text-emerald-600 bg-emerald-100 px-2 py-0.5 rounded-full">2 Nuevas</span>
        </div>
        <div class="divide-y divide-slate-100 max-h-80 overflow-auto">
          <a href="#" class="block px-4 py-3 hover:bg-slate-50 transition-colors">
            <p class="text-sm text-slate-800 font-medium">Nuevo pliego cargado</p>
            <p class="text-xs text-slate-500 mt-1">Licitación: Construcción Puente Sur</p>
            <p class="text-[10px] text-slate-400 mt-2">Hace 5 min</p>
          </a>
          <a href="#" class="block px-4 py-3 hover:bg-slate-50 transition-colors">
            <p class="text-sm text-slate-800 font-medium">Nuevo pliego cargado</p>
            <p class="text-xs text-slate-500 mt-1">Suministro de Equipos Médicos</p>
            <p class="text-[10px] text-slate-400 mt-2">Hace 2 horas</p>
          </a>
        </div>
      </div>
    </div>
    <div class="h-8 w-px bg-slate-200"></div>
    <button class="flex items-center gap-3 hover:text-slate-800 transition-colors">
      <div class="w-9 h-9 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-600 shadow-sm">
        <User size={18} />
      </div>
      <div class="flex flex-col items-start text-left">
        <span class="font-semibold text-sm leading-tight text-slate-800">Admin User</span>
        <span class="text-[10px] uppercase tracking-wider text-slate-400 font-bold">Supervisor</span>
      </div>
    </button>
  </div>
</header>

<script>
  import { $findings } from '../store/analysisStore';

  const countSpan = document.getElementById('header-findings-count');
  const badge = document.getElementById('header-findings-badge');
  
  $findings.subscribe(findings => {
    const unresolvedCount = findings.filter(f => !f.isResolved).length;
    if (countSpan) {
      countSpan.textContent = `${unresolvedCount} Hallazgos`;
      
      if (unresolvedCount === 0 && badge) {
        badge.classList.remove('bg-red-50', 'text-red-600', 'border-red-200');
        badge.classList.add('bg-emerald-50', 'text-emerald-600', 'border-emerald-200');
      }
    }
  });

  // Notification Dropdown Toggle
  const notifBtn = document.getElementById('notification-btn');
  const notifDropdown = document.getElementById('notification-dropdown');

  if (notifBtn && notifDropdown) {
    notifBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isHidden = notifDropdown.classList.contains('hidden');
      
      if (isHidden) {
        notifDropdown.classList.remove('hidden');
        // Small delay for transition
        setTimeout(() => {
          notifDropdown.classList.remove('opacity-0', 'scale-95');
          notifDropdown.classList.add('opacity-100', 'scale-100');
        }, 10);
      } else {
        notifDropdown.classList.remove('opacity-100', 'scale-100');
        notifDropdown.classList.add('opacity-0', 'scale-95');
        setTimeout(() => {
          notifDropdown.classList.add('hidden');
        }, 150); // match transition duration
      }
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!notifDropdown.contains(e.target as Node) && !notifDropdown.classList.contains('hidden')) {
        notifDropdown.classList.remove('opacity-100', 'scale-100');
        notifDropdown.classList.add('opacity-0', 'scale-95');
        setTimeout(() => {
          notifDropdown.classList.add('hidden');
        }, 150);
      }
    });
  }
</script>
