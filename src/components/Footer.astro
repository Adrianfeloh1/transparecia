---
import { CheckCircle2 } from 'lucide-react';
---

<footer class="bg-white/95 backdrop-blur-md border-t border-slate-200 px-8 py-4 flex justify-end gap-4 shadow-[0_-10px_20px_-10px_rgba(0,0,0,0.05)] z-20 transition-all">
  <div id="footer-actions-default" class="flex gap-4">
    <button id="btn-descartar" class="px-6 py-2.5 rounded-lg border border-slate-300 text-slate-700 font-semibold hover:bg-slate-50 hover:text-slate-900 transition-colors">
      Descartar
    </button>
    <button id="btn-aplicar" class="px-6 py-2.5 rounded-lg bg-slate-900 text-white font-semibold hover:bg-slate-800 shadow-md shadow-slate-900/20 transition-all">
      Aplicar Cambios
    </button>
  </div>
  
  <div id="footer-actions-review" class="hidden gap-4">
    <button id="btn-volver" class="px-6 py-2.5 rounded-lg border border-slate-300 text-slate-700 font-semibold hover:bg-slate-50 hover:text-slate-900 transition-colors">
      Volver a Edición
    </button>
    <button id="btn-aprobar" class="px-6 py-2.5 rounded-lg bg-emerald-600 text-white font-semibold hover:bg-emerald-700 shadow-md shadow-emerald-600/20 transition-all flex items-center gap-2">
      <CheckCircle2 size={18} strokeWidth={2.5} />
      Aprobar y Enviar a Firma
    </button>
  </div>
</footer>

<script>
  import { resetFindings, setReviewMode, $isReviewMode } from '../store/analysisStore';
  import { setView } from '../store/routerStore';

  const btnDescartar = document.getElementById('btn-descartar');
  const btnAplicar = document.getElementById('btn-aplicar');
  const btnAprobar = document.getElementById('btn-aprobar');
  const btnVolver = document.getElementById('btn-volver');
  const actionsDefault = document.getElementById('footer-actions-default');
  const actionsReview = document.getElementById('footer-actions-review');

  $isReviewMode.subscribe(isReview => {
    if (actionsDefault && actionsReview) {
      if (isReview) {
        actionsDefault.classList.add('hidden');
        actionsDefault.classList.remove('flex');
        actionsReview.classList.remove('hidden');
        actionsReview.classList.add('flex');
      } else {
        actionsDefault.classList.remove('hidden');
        actionsDefault.classList.add('flex');
        actionsReview.classList.add('hidden');
        actionsReview.classList.remove('flex');
      }
    }
  });

  if (btnDescartar) {
    btnDescartar.addEventListener('click', () => {
      resetFindings();
      setReviewMode(false);
    });
  }

  if (btnAplicar) {
    btnAplicar.addEventListener('click', () => {
      setReviewMode(true);
    });
  }

  if (btnAprobar) {
    btnAprobar.addEventListener('click', () => {
      alert("Documento aprobado y movido a la bandeja de firmas");
      setReviewMode(false);
      setView('flujos');
    });
  }

  if (btnVolver) {
    btnVolver.addEventListener('click', () => {
      setReviewMode(false);
    });
  }
</script>
